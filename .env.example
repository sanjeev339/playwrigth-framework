# Target Environment (dev, qa)
ENV=dev

# Only needed if not using a config/<env>.json file
BASE_URL=https://adminportal.dev.eigen-dyne.com/login/

# Admin credentials — NEVER commit real values here
USERNAME=your_admin_email@example.com
PASSWORD=your_admin_password

# Global Defaults
TIMEOUT=30000

# Set to any value to enable debug logging
# DEBUG=true
