# Target Environment (dev, qa)
ENV=dev

# Only needed if not using a config/<env>.json file
BASE_URL=https://adminportal.dev.eigen-dyne.com/login/

# Admin credentials — NEVER commit real values here
USERNAME=your_admin_email@example.com
PASSWORD=your_admin_password

# Global Defaults
TIMEOUT=30000

# Set to any value to enable debug logging
# DEBUG=true

# MCP Server Settings (optional overrides for default values in config/<env>.json)
# MCP_LLM_PROVIDER=openai
# MCP_GEMINI_MODEL=gemini-2.5-flash
# MCP_OPENAI_MODEL=gpt-4.1-mini
# MCP_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# MCP_LLM_TEMPERATURE=0.1
# MCP_OPENAI_MAX_TOKENS=12000
# MCP_ANTHROPIC_MAX_TOKENS=8000
# MCP_DISCOVERY_USER_LIST_API_PATH=/robolab/api/v1/user/list
# MCP_DISCOVERY_USER_LIST_PAGE_SIZE=100
# MCP_DISCOVERY_USER_LIST_MAX_PAGES=50
# MCP_DISCOVERY_USER_TYPE=Backoffice
