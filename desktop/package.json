{
  "name": "orchestai-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop MCP client for OrchestAI QA orchestration servers.",
  "main": "dist/electron/main/main.js",
  "scripts": {
    "clean:electron": "node -e \"require('fs').rmSync('dist/electron',{recursive:true,force:true})\"",
    "dev": "npm run clean:electron && concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist/electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "npm run build && electron .",
    "package": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "ai.orchest.desktop",
    "productName": "OrchestAI Desktop",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  }
}
